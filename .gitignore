build/

# ── Lokale omgevingen ─────────────────────────────────────────
.env
.env.*
*.local

# ── Scraper-toestand ──────────────────────────────────────────
# known_listings.json en geocode_cache.json: lokaal NIET inchecken
# GitHub Actions schrijft deze bestanden via git add -f terug naar de repo
known_listings.json
known_listings_local.json
geocode_cache.json

# ── Screenshots (worden door Actions via git add -f toegevoegd) ─
# Lokaal niet tracken; Actions pusht ze expliciet.
docs/screenshots/

# ── Gevoelige configuratie ────────────────────────────────────
# config.py bevat SMTP-wachtwoord als fallback — NOOIT inchecken!
# GitHub Actions genereert config.py at-runtime vanuit Secrets
config.py

